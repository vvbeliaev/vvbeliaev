---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import PostLayout from "../../components/PostLayout.astro";
import { postSlug } from "$lib/post";

export const getStaticPaths = (async () => {
  const posts = (
    await getCollection("blog", ({ data }) => !data.draft && data.lang === "en")
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return posts.map((post, i) => ({
    params: { slug: postSlug(post) },
    props: { post, prevPost: posts[i + 1], nextPost: posts[i - 1] },
  }));
}) satisfies GetStaticPaths;

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<PostLayout post={post} prevPost={prevPost} nextPost={nextPost} lang="en">
  <Content />
</PostLayout>
