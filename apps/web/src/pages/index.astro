---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "$lib/config";
import { Button } from "$lib/components/ui/button/index.js";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="py-8">
    <h1
      class="font-display text-4xl font-extrabold tracking-tight sm:text-5xl"
    >
      {SITE.title}
    </h1>
    <p class="mt-3 text-lg text-muted-foreground">{SITE.tagline}</p>
    <p class="mt-6 max-w-2xl leading-relaxed">
      I write long-form posts on AI, product and analytics. This is a field log:
      numbered notes, breakdowns and by-the-numbers recaps.
    </p>
    <div class="mt-6">
      <Button href="/blog" class="glow-primary">Read the blog</Button>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="mt-12">
        <h2 class="text-sm font-medium uppercase tracking-wide text-muted-foreground">
          Latest notes
        </h2>
        <ul class="mt-4 space-y-4">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="group block rounded-lg border border-border bg-card/40 p-4 transition-colors hover:border-primary/40 hover:bg-card"
              >
                <span class="font-medium group-hover:underline">
                  {post.data.noteNumber ? `Note #${post.data.noteNumber}. ` : ""}
                  {post.data.title}
                </span>
                <span class="mt-1 block text-sm text-muted-foreground">
                  {post.data.description}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
