---
/*
  Work.astro — selected work. The `featured` project (Space N Place) gets the
  accent treatment; the rest sit in a compact grid. Everything links out to the
  live products — no bespoke pages.
*/
import { PROJECTS } from "$lib/config";
import { getLangFromUrl, useTranslations } from "$i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const featured = PROJECTS.find((p) => p.featured);
const others = PROJECTS.filter((p) => !p.featured);
---

<section class="mt-14">
  <h2 class="font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground">
    {t("home.work")}
  </h2>

  {
    featured && (
      <a
        href={featured.href}
        target="_blank"
        rel="noopener noreferrer"
        class="group glow-primary mt-4 block rounded-xl border border-primary/40 bg-card/60 p-6 transition-colors hover:border-primary"
      >
        <div class="flex items-center justify-between">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-primary">
            {featured.tag}
          </span>
          <span class="text-muted-foreground transition-colors group-hover:text-primary">
            ↗
          </span>
        </div>
        <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">
          {featured.name}
        </h3>
        <p class="mt-1.5 text-muted-foreground">{featured.description}</p>
        {featured.highlights && (
          <ul class="mt-3 flex flex-wrap gap-2">
            {featured.highlights.map((h) => (
              <li class="rounded-full border border-border bg-background/40 px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-muted-foreground">
                {h}
              </li>
            ))}
          </ul>
        )}
      </a>
    )
  }

  <ul class="mt-3 space-y-3">
    {
      others.map((p) => (
        <li>
          <a
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-baseline justify-between gap-4 rounded-lg border border-border bg-card/40 p-4 transition-colors hover:border-primary/40 hover:bg-card"
          >
            <div class="min-w-0">
              <span class="font-display font-semibold tracking-tight">
                {p.name}
              </span>
              <span class="ml-2 font-mono text-[10px] uppercase tracking-wider text-muted-foreground">
                {p.tag}
              </span>
              <p class="mt-1 text-sm text-muted-foreground">{p.description}</p>
            </div>
            <span class="shrink-0 text-muted-foreground transition-colors group-hover:text-primary">
              ↗
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
