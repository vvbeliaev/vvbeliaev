---
/*
  Manifesto.astro — why market-first, as a diptych in the theme's grammar:
  left, "the commodity" — a uniform steel grid of dots (everyone's demo looks
  the same); right, "the edge" — a small coral constellation (knowing what to
  build). One conclusion line and a slim numbers readout underneath.
  NOTE: strawman numbers — adjust values/labels in i18n once locked.
*/
import { getLangFromUrl, useTranslations } from "$i18n/utils";
import type { UIKey } from "$i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const numbers = ["1", "2", "3"].map((n) => ({
  value: t(`numbers.${n}.value` as UIKey),
  label: t(`numbers.${n}.label` as UIKey),
}));

// The commodity: a perfectly regular grid — uniformity is the point.
const GRID = Array.from({ length: 60 }, (_, i) => ({
  x: 14 + (i % 10) * 20,
  y: 14 + Math.floor(i / 10) * 20,
}));

// The edge: a small confirmed pattern read out of the same kind of dots.
const EDGE_NODES = [
  { x: 28, y: 96 },
  { x: 62, y: 68 },
  { x: 96, y: 80 },
  { x: 136, y: 44 },
  { x: 172, y: 24 },
];
const EDGE_POINTS = EDGE_NODES.map((n) => `${n.x},${n.y}`).join(" ");
---

<section class="mx-auto max-w-5xl px-6 py-24 sm:py-28">
  <h2 class="font-mono text-xs uppercase tracking-[0.3em] text-accent">
    {t("manifesto.label")}
  </h2>

  <div class="mt-8 grid gap-px overflow-hidden rounded-xl border border-border bg-border sm:grid-cols-2">
    <div class="relative bg-card/70 p-7 sm:p-9">
      <svg
        class="pointer-events-none absolute inset-0 h-full w-full opacity-[0.13]"
        viewBox="0 0 200 130"
        preserveAspectRatio="xMidYMid slice"
        aria-hidden="true"
      >
        {GRID.map((d) => <circle cx={d.x} cy={d.y} r="1.4" fill="#5f95c2" />)}
      </svg>
      <p class="relative font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
        {t("manifesto.commodity.label")}
      </p>
      <h3 class="relative mt-3 font-display text-2xl font-bold tracking-tight sm:text-3xl">
        {t("manifesto.commodity.title")}<span class="text-accent">.</span>
      </h3>
      <p class="relative mt-3 leading-relaxed text-muted-foreground">
        {t("manifesto.commodity.body")}
      </p>
    </div>

    <div class="relative bg-card p-7 sm:p-9">
      <svg
        class="pointer-events-none absolute right-4 top-4 h-24 w-44 opacity-70 sm:h-28 sm:w-52"
        viewBox="0 0 200 120"
        fill="none"
        aria-hidden="true"
      >
        <polyline points={EDGE_POINTS} stroke="rgba(240,138,114,0.65)" stroke-width="1.2"></polyline>
        {
          EDGE_NODES.map((n, i) => (
            <circle
              cx={n.x}
              cy={n.y}
              r={i === EDGE_NODES.length - 1 ? 3 : 2}
              fill="#f08a72"
              opacity={i === EDGE_NODES.length - 1 ? 1 : 0.75}
            />
          ))
        }
      </svg>
      <p class="relative font-mono text-[11px] uppercase tracking-[0.25em] text-primary">
        {t("manifesto.edge.label")}
      </p>
      <h3 class="relative mt-3 font-display text-2xl font-bold tracking-tight sm:text-3xl">
        {t("manifesto.edge.title")}<span class="text-primary">.</span>
      </h3>
      <p class="relative mt-3 leading-relaxed text-muted-foreground">
        {t("manifesto.edge.body")}
      </p>
    </div>
  </div>

  <p class="mt-8 max-w-3xl text-lg leading-relaxed text-foreground sm:text-xl">
    {t("manifesto.conclusion")}
  </p>

  <dl class="mt-8 flex flex-wrap items-baseline gap-x-10 gap-y-4">
    {
      numbers.map((s) => (
        <div class="flex items-baseline gap-2.5">
          <dt class="font-display text-2xl font-bold tracking-tight text-foreground">{s.value}</dt>
          <dd class="max-w-52 font-mono text-[10px] uppercase leading-relaxed tracking-wider text-muted-foreground">
            {s.label}
          </dd>
        </div>
      ))
    }
  </dl>
</section>
