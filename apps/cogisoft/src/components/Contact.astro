---
import { SITE } from "$lib/config";
import { getLangFromUrl, useTranslations } from "$i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="mx-auto max-w-3xl px-6 py-24 text-center sm:py-32">
  <h2 class="font-mono text-xs uppercase tracking-[0.3em] text-accent">
    {t("contact.label")}
  </h2>
  <p class="mt-5 font-display text-4xl font-extrabold tracking-tight text-balance sm:text-5xl">
    {t("contact.title")}<span class="text-primary">.</span>
  </p>
  <p class="mt-4 text-lg text-muted-foreground">
    {t("contact.sub")}
  </p>
  <a
    href={`mailto:${SITE.email}`}
    class="glow-primary mt-10 inline-block rounded-lg bg-primary px-8 py-4 font-mono text-sm font-semibold tracking-wide text-primary-foreground transition-[filter] hover:brightness-110"
  >
    {SITE.email}
  </a>
  <p class="mt-6 text-sm text-muted-foreground">
    {t("contact.note")}
  </p>
</section>
