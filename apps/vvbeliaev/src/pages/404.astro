---
// Single static 404 (served as /404.html for every path), so the URL locale
// can't be resolved here — keep it compactly bilingual (EN + RU).
import BaseLayout from "../layouts/BaseLayout.astro";
import { Button } from "$lib/components/ui/button/index.js";
import { ui } from "$i18n/ui";
---

<BaseLayout title="Page not found · Страница не найдена" description="404">
  <section class="py-16 text-center">
    <p class="text-6xl font-semibold tracking-tight">404</p>
    <p class="mt-4 text-lg text-muted-foreground">{ui.en["notfound.body"]}</p>
    <p class="mt-1 text-lg text-muted-foreground">{ui.ru["notfound.body"]}</p>
    <div class="mt-8 flex items-center justify-center gap-3">
      <Button href="/">{ui.en["notfound.back"]}</Button>
      <Button href="/ru">{ui.ru["notfound.back"]}</Button>
    </div>
  </section>
</BaseLayout>
