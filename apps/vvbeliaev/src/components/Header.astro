---
import { NAV, FOLLOW, SITE, SITE_I18N } from "$lib/config";
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  getAlternatePath,
} from "$i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizePath("/", lang);
const name = SITE_I18N[lang].name;

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === home ? pathname === home : pathname.startsWith(href);

// Language segments: both locales shown, active one highlighted. Each links to
// the equivalent page in that locale (the active one links to itself).
const LANG_SEGMENTS = [
  { code: "EN", value: "en" },
  { code: "RU", value: "ru" },
] as const;
const langOptions = LANG_SEGMENTS.map((seg) => ({
  ...seg,
  href: getAlternatePath(Astro.url, seg.value),
  current: seg.value === lang,
}));

const navItems = NAV.map((item) => ({
  href: localizePath(item.href, lang),
  label: t(item.key),
}));
---

<header class="relative border-b border-border">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
    <!-- Brand: full wordmark on ≥sm, the V-constellation site mark on mobile -->
    <a
      href={home}
      class="hidden font-display font-bold tracking-tight sm:block"
      aria-label={name}
    >
      {SITE.handle}
    </a>
    <a href={home} class="site-mark inline-flex items-center sm:hidden" aria-label={name}>
      <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
        <polyline
          points="8,9 16,24 24,9"
          fill="none"
          stroke="#5f95c2"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          opacity="0.6"
        />
        <g fill="#8fb4d8">
          <circle cx="8" cy="9" r="2" />
          <circle cx="24" cy="9" r="2" />
        </g>
        <circle cx="16" cy="24" r="5.4" fill="#5f95c2" opacity="0.18" />
        <circle cx="16" cy="24" r="2.4" fill="#e6eefb" />
      </svg>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 sm:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "rounded-md px-3 py-1.5 text-sm transition-colors hover:bg-secondary hover:text-foreground",
              isActive(item.href) ? "text-foreground" : "text-muted-foreground",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <div
        class="ml-2 flex items-center gap-1.5 rounded-md border border-border px-2 py-1"
        role="group"
        aria-label={t("lang.aria")}
      >
        <svg
          class="h-3.5 w-3.5 text-muted-foreground"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
          <path d="M2 12h20" />
        </svg>
        <div class="flex items-center font-mono text-xs uppercase tracking-wider">
          {
            langOptions.map((opt, i) => (
              <>
                {i > 0 && <span class="px-0.5 text-border" aria-hidden="true">/</span>}
                {opt.current ? (
                  <span class="font-semibold text-primary" aria-current="true">
                    {opt.code}
                  </span>
                ) : (
                  <a
                    href={opt.href}
                    class="text-muted-foreground transition-colors hover:text-foreground"
                    aria-label={t(`lang.to.${opt.value}`)}
                  >
                    {opt.code}
                  </a>
                )}
              </>
            ))
          }
        </div>
      </div>
    </nav>

    <!-- Mobile trigger: a hamburger that morphs into an × when the drawer opens. -->
    <button
      type="button"
      class="menu-trigger -mr-1.5 inline-flex h-9 w-9 items-center justify-center rounded-md sm:hidden"
      data-menu-trigger
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label={t("menu.open")}
      data-label-open={t("menu.open")}
      data-label-close={t("menu.close")}
    >
      <span class="menu-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="mobile-menu sm:hidden" data-open="false" inert>
    <div class="menu-backdrop" data-menu-close></div>
    <div class="menu-panel" role="dialog" aria-modal="true" aria-label={name}>
      <nav class="grid gap-1">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-3 rounded-lg px-3 py-3 font-display text-xl tracking-tight transition-colors",
                isActive(item.href)
                  ? "bg-secondary text-foreground"
                  : "text-muted-foreground hover:bg-secondary/60 hover:text-foreground",
              ]}
            >
              <span
                class:list={[
                  "led-indicator transition-opacity",
                  isActive(item.href) ? "text-primary" : "text-border",
                ]}
              />
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="mt-6 border-t border-border pt-5">
        <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
          {t("lang.aria")}
        </span>
        <div class="mt-3 flex gap-2 font-mono text-sm uppercase tracking-wider">
          {
            langOptions.map((opt) =>
              opt.current ? (
                <span
                  class="rounded-md border border-primary/40 bg-primary/10 px-3 py-1.5 font-semibold text-primary"
                  aria-current="true"
                >
                  {opt.code}
                </span>
              ) : (
                <a
                  href={opt.href}
                  class="rounded-md border border-border px-3 py-1.5 text-muted-foreground transition-colors hover:border-primary/40 hover:text-foreground"
                  aria-label={t(`lang.to.${opt.value}`)}
                >
                  {opt.code}
                </a>
              ),
            )
          }
        </div>
      </div>

      <div class="mt-6 border-t border-border pt-5">
        <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
          {t("home.follow")}
        </span>
        <ul class="mt-3 grid gap-2">
          {
            FOLLOW.map((c) => (
              <li>
                <a
                  href={c.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between gap-4 rounded-lg border border-border bg-card/40 px-3 py-2.5 transition-colors hover:border-primary/40 hover:bg-card"
                >
                  <span class="flex items-center gap-2.5">
                    {c.primary && <span class="led-indicator text-primary" />}
                    <span class="font-medium">{c.label}</span>
                  </span>
                  <span class="font-mono text-xs text-muted-foreground group-hover:text-foreground">
                    {c.handle}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</header>

<style>
  /* Mobile brand mark — the V-constellation site mark (favicon). */
  .site-mark svg {
    transition: filter 0.25s ease;
  }
  .site-mark:hover svg,
  .site-mark:focus-visible svg {
    filter: drop-shadow(0 0 6px color-mix(in oklch, var(--accent) 70%, transparent));
  }

  /* Hamburger → × trigger */
  .menu-trigger {
    color: var(--muted-foreground);
    transition: color 0.2s ease;
  }
  .menu-trigger:hover,
  .menu-trigger:focus-visible {
    color: var(--foreground);
  }
  .menu-trigger[aria-expanded="true"] {
    color: var(--primary);
  }
  .menu-bars {
    position: relative;
    width: 1.25rem;
    height: 0.85rem;
  }
  .menu-bars span {
    position: absolute;
    left: 0;
    right: 0;
    height: 1.6px;
    border-radius: 2px;
    background: currentColor;
    transition:
      transform 0.25s ease,
      opacity 0.2s ease;
  }
  .menu-bars span:nth-child(1) {
    top: 0;
  }
  .menu-bars span:nth-child(2) {
    top: 50%;
    transform: translateY(-50%);
  }
  .menu-bars span:nth-child(3) {
    bottom: 0;
  }
  .menu-trigger[aria-expanded="true"] .menu-bars span:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }
  .menu-trigger[aria-expanded="true"] .menu-bars span:nth-child(2) {
    opacity: 0;
  }
  .menu-trigger[aria-expanded="true"] .menu-bars span:nth-child(3) {
    bottom: auto;
    top: 50%;
    transform: translateY(-50%) rotate(-45deg);
  }

  /* Drawer */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 60;
  }
  .mobile-menu[data-open="false"] {
    pointer-events: none;
    visibility: hidden;
  }
  .menu-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--background) 72%, transparent);
    backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .mobile-menu[data-open="true"] .menu-backdrop {
    opacity: 1;
  }
  .menu-panel {
    position: absolute;
    inset: 0.75rem 0.75rem auto 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-top: 2px solid var(--primary);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(
        120% 80% at 100% 0%,
        color-mix(in oklch, var(--primary) 12%, transparent),
        transparent 55%
      ),
      var(--card);
    box-shadow: 0 24px 60px -24px rgb(0 0 0 / 0.7);
    opacity: 0;
    transform: translateY(-10px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }
  .mobile-menu[data-open="true"] .menu-panel {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-backdrop,
    .menu-panel,
    .menu-bars span,
    .site-mark svg {
      transition: none;
    }
  }
</style>

<script>
  // Mobile drawer: toggle [data-open], lock scroll, manage focus + Escape.
  const trigger = document.querySelector<HTMLButtonElement>("[data-menu-trigger]");
  const menu = document.getElementById("mobile-menu");

  if (trigger && menu) {
    const panelLink = menu.querySelector<HTMLAnchorElement>("a");
    const labelOpen = trigger.dataset.labelOpen ?? "Open menu";
    const labelClose = trigger.dataset.labelClose ?? "Close menu";

    const isOpen = () => menu.dataset.open === "true";

    const open = () => {
      menu.dataset.open = "true";
      menu.removeAttribute("inert");
      trigger.setAttribute("aria-expanded", "true");
      trigger.setAttribute("aria-label", labelClose);
      document.documentElement.style.overflow = "hidden";
      panelLink?.focus();
    };

    const close = (returnFocus = true) => {
      menu.dataset.open = "false";
      menu.setAttribute("inert", "");
      trigger.setAttribute("aria-expanded", "false");
      trigger.setAttribute("aria-label", labelOpen);
      document.documentElement.style.overflow = "";
      if (returnFocus) trigger.focus();
    };

    trigger.addEventListener("click", () => (isOpen() ? close() : open()));

    menu.querySelectorAll("[data-menu-close]").forEach((el) =>
      el.addEventListener("click", () => close()),
    );

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen()) close();
    });
  }
</script>
