---
/*
  StatStrip.astro — the "by the numbers" ritual as a HUD readout.
  NOTE: strawman placeholder numbers; final values + i18n once locked.
*/
const stats = [
  { value: "5", unit: "yrs", label: "building" },
  { value: "12", unit: "", label: "products shipped" },
  { value: "40", unit: "", label: "field notes" },
  { value: "3", unit: "", label: "disciplines, one stack" },
];
---

<section class="mt-14">
  <h2 class="font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground">
    By the numbers
  </h2>
  <dl class="mt-4 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-4">
    {
      stats.map((s) => (
        <div class="bg-card px-4 py-5">
          <dt class="font-display text-3xl font-bold tracking-tight text-foreground">
            {s.value}
            {s.unit && (
              <span class="ml-1 text-base font-medium text-muted-foreground">
                {s.unit}
              </span>
            )}
          </dt>
          <dd class="mt-1 font-mono text-[11px] uppercase tracking-wider text-muted-foreground">
            {s.label}
          </dd>
        </div>
      ))
    }
  </dl>
</section>
